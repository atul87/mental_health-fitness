{
  "name": "mental-health-backend",
  "version": "1.0.0",
  "description": "Backend for Mental Health application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:backend": "jest --runInBand",
    "test:frontend": "npm --prefix Mental-health test",
    "lint:frontend": "npm --prefix Mental-health run lint",
    "build:frontend": "npm --prefix Mental-health run build",
    "coverage:backend": "jest --runInBand --coverage",
    "coverage:frontend": "npm --prefix Mental-health run coverage",
    "ci:check": "npm run test:backend && npm run test:frontend && npm run lint:frontend && npm run build:frontend"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"],
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "middleware/**/*.js",
      "models/**/*.js",
      "routes/**/*.js",
      "server.js",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "coverage/backend"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^6.3.0",
    "mongoose": "^9.4.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^2.0.20",
    "supertest": "^7.2.2"
  }
}
